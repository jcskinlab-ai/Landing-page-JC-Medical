{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "(www\\.)?jcmedical\\.cl" }], "destination": "/app", "permanent": false },
    { "source": "/panel", "has": [{ "type": "host", "value": "(www\\.)?jcmedical\\.cl" }], "destination": "https://portal.medique.cl/", "permanent": false },
    { "source": "/panel/:path*", "has": [{ "type": "host", "value": "(www\\.)?jcmedical\\.cl" }], "destination": "https://portal.medique.cl/:path*", "permanent": false },
    { "source": "/admin", "has": [{ "type": "host", "value": "(www\\.)?jcmedical\\.cl" }], "destination": "https://admin.medique.cl/", "permanent": false },
    { "source": "/super", "has": [{ "type": "host", "value": "(www\\.)?jcmedical\\.cl" }], "destination": "https://admin.medique.cl/", "permanent": false },
    { "source": "/panel", "has": [{ "type": "host", "value": "(www\\.)?medique\\.cl" }], "destination": "https://portal.medique.cl/", "permanent": false },
    { "source": "/panel/:path*", "has": [{ "type": "host", "value": "(www\\.)?medique\\.cl" }], "destination": "https://portal.medique.cl/:path*", "permanent": false },
    { "source": "/admin", "has": [{ "type": "host", "value": "(www\\.)?medique\\.cl" }], "destination": "https://admin.medique.cl/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "portal.medique.cl" }], "destination": "/JC_Admin" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "admin.medique.cl" }], "destination": "/super" },
    { "source": "/", "has": [{ "type": "host", "value": "(www\\.)?medique\\.cl" }], "destination": "/medique-home" },
    { "source": "/app", "destination": "/JC_App" },
    { "source": "/reservar", "destination": "/agendar" },
    { "source": "/movil", "destination": "/JC_Mobile" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' *.gstatic.com *.googleapis.com *.firebaseapp.com *.firebaseio.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' unpkg.com www.gstatic.com www.google.com cdn.jsdelivr.net cdnjs.cloudflare.com esm.sh; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data: blob: *; frame-src 'self' www.google.com www.gstatic.com; connect-src 'self' *.googleapis.com *.firebaseio.com *.firebaseapp.com www.google.com api.groq.com"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/(JC_App|JC_Admin|JC_Mobile|agendar|index|super|review|colaborar|medique-home)(.html)?",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.(js|jsx|css|png|jpg|jpeg|webp|svg|woff2)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
