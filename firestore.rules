rules_version = '2';
// ════════════════════════════════════════════════════════════════════════
// Reglas de seguridad de Firestore para el SaaS multi-clínica de JC Medical.
// Pega TODO esto en: Firebase Console → Firestore Database → pestaña "Reglas".
// Aíslan los datos: cada clínica solo puede leer/escribir lo suyo.
// ════════════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // clinicId al que pertenece el usuario logueado (según su doc en users/).
    function myClinic() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clinicId;
    }

    // SUPER-ADMIN (dueño del SaaS): preferimos el custom claim (seteado con Admin SDK,
    // no se puede auto-asignar). Se MANTIENEN los correos de los dueños como respaldo para
    // no quedar bloqueados de /admin. Quita la lista de correos SOLO cuando confirmes que
    // ambas cuentas tienen el claim. Setear claim: auth.setCustomUserClaims(uid,{superAdmin:true}).
    function isSuper() {
      return signedIn() && (request.auth.token.superAdmin == true
                            || request.auth.token.email == 'medique.cl@gmail.com'
                            || request.auth.token.email == 'jc.skinlab@gmail.com');
    }

    // Plan activo: active, comp o trial vigente (validado en servidor, no en cliente).
    function clinicActive(clinicId) {
      let c = get(/databases/$(database)/documents/clinics/$(clinicId)).data;
      return c.plan == 'active' || c.plan == 'comp'
        || (c.plan == 'trial' && c.trialEnds > request.time.toMillis());
    }

    // Mapeo usuario → clínica (uid, clinicId, rol). Cada quien gestiona el suyo.
    match /users/{uid} {
      allow read:          if signedIn() && request.auth.uid == uid;
      // C-01: solo puedes mapearte a una clínica de la que eres DUEÑO. El doc clinics/{id} se
      // crea ANTES (con ownerUid = tu uid), así que aquí se puede exigir la pertenencia. Los
      // profesionales los crea el Admin SDK (team-access.js), que ignora estas reglas.
      allow create:        if signedIn() && request.auth.uid == uid
                           && request.resource.data.clinicId is string
                           && get(/databases/$(database)/documents/clinics/$(request.resource.data.clinicId)).data.ownerUid == request.auth.uid;
      // En update, el clinicId NO puede cambiar: evita que un usuario se reasigne a otra clínica
      // y obtenga acceso a sus datos (myClinic() lee este campo).
      // SEG · role/perms/createdBy también se congelan: son campos de AUTORIZACIÓN y este doc lo
      // escribe el propio usuario. Sin esto, un profesional se ponía role:'owner' (o borraba el
      // campo, porque api/team-access.js usaba el fallback "owner") y pasaba a gestionar accesos
      // de la clínica: crear cuentas, fijar contraseñas y revocar a otros. Solo el Admin SDK
      // (api/team-access.js, que ignora estas reglas) debe escribirlos.
      // Se usa .get(campo, default) para no romper en docs antiguos que no traigan el campo.
      allow update:        if signedIn() && request.auth.uid == uid
                           && request.resource.data.clinicId == resource.data.clinicId
                           && request.resource.data.get('role', '') == resource.data.get('role', '')
                           && request.resource.data.get('perms', {}) == resource.data.get('perms', {})
                           && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '');
      // Solo el super-admin puede eliminar el mapeo (al borrar una clínica desde la consola).
      allow delete:        if isSuper();
    }

    // Perfil de la clínica (nombre, marca, plan, prueba).
    match /clinics/{clinicId} {
      // Al registrarse, la clínica nace PENDIENTE (no puede auto-asignarse un plan pagado ni de
      // prueba): se obliga plan='pending'. El super-admin la aprueba desde /admin (pasa a 'trial').
      allow create: if signedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && clinicId == request.resource.data.id
                    && request.resource.data.plan == 'pending';
      // La clínica puede leer y editar su perfil/marca…
      allow read:   if isSuper() || (signedIn()
                    && (resource.data.ownerUid == request.auth.uid || myClinic() == clinicId));
      // El super-admin puede cambiar el plan/prueba; la clínica puede editar su perfil/marca
      // pero NO su propio plan/prueba/propietario (así nadie se auto-activa gratis para siempre).
      allow update: if isSuper() || (signedIn()
                    && (resource.data.ownerUid == request.auth.uid || myClinic() == clinicId)
                    && request.resource.data.plan      == resource.data.plan
                    && request.resource.data.trialEnds == resource.data.trialEnds
                    && request.resource.data.ownerUid  == resource.data.ownerUid);
      // Solo el super-admin puede eliminar una clínica (consola /admin).
      allow delete: if isSuper();
    }

    // Datos de cada clínica (agenda, pacientes, caja, inventario, etc.), aislados.
    // La clínica debe tener plan activo o trial vigente (validado aquí, no solo en el cliente).
    match /tenants/{clinicId}/kv/{key} {
      allow read, write: if signedIn()
                         && myClinic() == clinicId
                         && (isSuper() || clinicActive(clinicId));
    }

    // Perfil público de la clínica (marca, dirección, horarios, precios) para la
    // app de pacientes y la reserva. Lectura libre; solo la clínica lo escribe.
    // SEG · Antes era /public/{doc} con comodín y sin clinicActive: cualquier miembro de la clínica
    // —incluida una en plan 'pending' nunca aprobada— podía escribir documentos arbitrarios de
    // hasta 1 MiB en una ruta de lectura pública (defacement de la página de reserva, o el proyecto
    // usado como hosting de contenido ajeno). El único doc que la app usa es 'profile'.
    // NOTA para el dueño: este doc es de lectura LIBRE y hoy incluye los datos de transferencia
    // (banco, titular, RUT, número) — quien conozca el clinicId, que va en las URLs públicas ?c=,
    // los puede leer. Es intencional para la reserva, pero conviene decidirlo a conciencia.
    match /tenants/{clinicId}/public/profile {
      allow read:  if true;
      allow write: if signedIn() && myClinic() == clinicId && clinicActive(clinicId);
    }

    // Reservas que dejan los pacientes (sin login): pueden CREAR una reserva en su
    // clínica, pero no leer/editar las de otros. La clínica (logueada) las gestiona.
    match /tenants/{clinicId}/bookings/{id} {
      allow create: if request.resource.data.keys().hasOnly(['name','phone','email','proc','fecha','time','dur','procs','note','createdAt','source'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 120
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() < 30
                    // SEG · hay que exigir `is string` ANTES de .size(): sobre una lista, .size()
                    // devuelve el NÚMERO DE ELEMENTOS, no bytes. Sin el chequeo de tipo bastaba
                    // mandar note: ["<100 KB>", "<100 KB>", ...] (size()=5) para colar un doc de
                    // ~1 MiB y llenar la bandeja de reservas de cualquier clínica activa.
                    && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() < 1000))
                    && (!('proc' in request.resource.data) || (request.resource.data.proc is string && request.resource.data.proc.size() < 200))
                    && (!('email' in request.resource.data) || (request.resource.data.email is string && request.resource.data.email.size() < 160))
                    && (!('fecha' in request.resource.data) || (request.resource.data.fecha is string && request.resource.data.fecha.size() < 20))
                    && (!('time' in request.resource.data) || (request.resource.data.time is string && request.resource.data.time.size() < 20))
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt >= request.time.toMillis() - 300000
                    && request.resource.data.createdAt <= request.time.toMillis() + 300000
                    && clinicActive(clinicId);
      allow read, update, delete: if signedIn() && myClinic() == clinicId;
    }

    // Colaboraciones que envían influencers/marcas desde el formulario público (sin login).
    match /tenants/{clinicId}/collabs/{id} {
      allow create: if request.resource.data.keys().hasOnly(['name','email','phone','kind','ig','tiktok','ciudad','redPrincipal','reach','views','audiencia','ofrece','proc','message','createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 120
                    // SEG · `is string` antes de .size() (ver el comentario en bookings).
                    && (!('message' in request.resource.data) || (request.resource.data.message is string && request.resource.data.message.size() < 2000))
                    && (!('ofrece' in request.resource.data) || (request.resource.data.ofrece is string && request.resource.data.ofrece.size() < 1000))
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt >= request.time.toMillis() - 300000
                    && request.resource.data.createdAt <= request.time.toMillis() + 300000
                    && clinicActive(clinicId);
      allow read, update, delete: if signedIn() && myClinic() == clinicId;
    }

    // Usuarios registrados en la app de la clínica (el paciente se registra sin login).
    // El doc ID es el teléfono normalizado (solo dígitos) → idempotente.
    match /tenants/{clinicId}/appusers/{doc} {
      // C-02: el ALTA pública se acota como las reservas (shape + createdAt ±5 min + clínica
      // activa) para bloquear spam masivo y altas en clínicas inexistentes/suspendidas.
      allow create: if request.resource.data.keys().hasOnly(['name','phone','email','points','created','createdAt'])
                    // OJO: request.resource.data.size() cuenta CLAVES del mapa, no bytes; con el
                    // hasOnly de 6 claves este chequeo no aporta nada. Los topes reales son los de
                    // tipo/longitud de abajo.
                    && (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() < 120))
                    && (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() < 30))
                    && (!('email' in request.resource.data) || (request.resource.data.email is string && request.resource.data.email.size() < 160))
                    // SEG · `points` venía en el hasOnly SIN restringir su valor: un paciente se
                    // registraba con points: 999999 e importWebAppUsers los copiaba tal cual al
                    // panel, canjeando descuentos falsos. El alta anónima debe traer 0; solo la
                    // clínica logueada puede fijar puntos.
                    && ((signedIn() && myClinic() == clinicId)
                        || !('points' in request.resource.data)
                        || request.resource.data.points == 0)
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt >= request.time.toMillis() - 300000
                    && request.resource.data.createdAt <= request.time.toMillis() + 300000
                    && clinicActive(clinicId);
      // C-02: el UPDATE ya NO es público → nadie anónimo puede sobrescribir/pisar los usuarios
      // de otra clínica. Solo la clínica logueada ajusta puntos/datos de SUS usuarios.
      allow read, update, delete: if signedIn() && myClinic() == clinicId;
    }

    // Portal del paciente · material de autenticación (hash de clave, salt, preguntas de
    // seguridad, estado de autorización). SOLO el servidor (Admin SDK, que ignora estas reglas)
    // puede leer/escribir. El navegador del paciente NUNCA toca Firestore: entra por /api/portal.
    // El deny explícito documenta que ningún cliente debe acceder aquí.
    match /tenants/{clinicId}/portalauth/{rutKey} {
      allow read, write: if false;
    }

    // Reseñas que dejan los pacientes desde el formulario público (sin login).
    match /tenants/{clinicId}/reviews/{id} {
      allow create: if request.resource.data.keys().hasOnly(['name','phone','stars','comment','createdAt'])
                    && request.resource.data.stars is number
                    && request.resource.data.stars >= 1 && request.resource.data.stars <= 5
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 120
                    // SEG · `is string` antes de .size() (ver el comentario en bookings).
                    && (!('comment' in request.resource.data) || (request.resource.data.comment is string && request.resource.data.comment.size() < 2000))
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt >= request.time.toMillis() - 300000
                    && request.resource.data.createdAt <= request.time.toMillis() + 300000
                    && clinicActive(clinicId);
      allow read, update, delete: if signedIn() && myClinic() == clinicId;
    }

    // Portal del paciente · índice global RUT → clínica (para resolver la clínica al hacer login
    // solo con el RUT). SOLO el servidor (Admin SDK) lo escribe/lee. Deny explícito para clientes.
    match /portalIndex/{rutKey} {
      allow read, write: if false;
    }
  }
}
